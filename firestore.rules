rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Users can read any user profile if authenticated (names, emails, household IDs)
    // but can only write to their own profile.
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Households can be read/written if:
    // 1. It is the user's own default household (ID matches their UID) - prevents race conditions.
    // 2. The user's profile document has householdId matching the household.
    match /households/{householdId} {
      allow read, write: if request.auth != null && (
        householdId == request.auth.uid ||
        get(/databases/(default)/documents/users/$(request.auth.uid)).data.householdId == householdId
      );
    }
    
    // Home Assistant tokens are unguessable UUIDs. 
    // Anyone with the exact UUID can read the summary data.
    match /ha_tokens/{tokenId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
