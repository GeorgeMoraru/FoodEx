rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Users can read/write their own document. 
    // They can read other user documents if they share the same householdId.
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      allow read: if request.auth != null && 
        userId != request.auth.uid &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.householdId == resource.data.householdId;
    }
    
    // Households can be read/written if:
    // 1. It is the user's own default household (ID matches their UID) - bypasses DB lookup to prevent race conditions on first sign-in.
    // 2. The user's profile document has householdId matching the household.
    match /households/{householdId} {
      allow read, write: if request.auth != null && (
        householdId == request.auth.uid ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.householdId == householdId)
      );
    }
    
    // Home Assistant tokens are unguessable UUIDs. 
    // Anyone with the exact UUID can read the summary data.
    match /ha_tokens/{tokenId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
